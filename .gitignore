# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# release artifacts (scripts/build-release.mjs)
/dist

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# ---- GameHub: user data & secrets — NEVER commit these ----
# live data: database (accounts/password hashes/sessions/provider creds),
# scraped media, saves, firmware
/data/
/data-docker/
# backup archives
gamehub-backup-*.tar
# SQLite files anywhere (safety net)
*.db
*.db-wal
*.db-shm
*.sqlite
# credentials/keys (safety net; *.pem already above)
*.key
credentials*.json
sscreds*.json
# embedded ScreenScraper app credentials (encrypted blob) — ships only in
# the Docker image, never in the repo; scripts/ensure-ssdev.mjs recreates
# an empty one so fresh clones build
/src/lib/providers/ssdev.generated.ts

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# claude
CLAUDE.md
AGENTS.md
.claude/*
scratchpad/*

# local reference captures (Valve UI snapshots — never commit/redistribute)
/refs/
